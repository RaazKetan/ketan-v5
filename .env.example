# Server-only secrets (set in Vercel project settings).
# These are NEVER exposed to the client.

# Sarvam AI key for TTS/STT + the RAG agent's LLM generation —
# proxied through api/sarvam/* edge functions.
SARVAM_API_KEY=

# Google Gemini key for the RAG agent's semantic embeddings
# (text-embedding-004) — proxied through api/embed.ts.
GEMINI_API_KEY=

# Optional comma-separated origin allow-list for the proxy.
# Defaults to the production Vercel domains + localhost in dev.
# Example: https://ketan-v5.vercel.app,https://ketanraj.dev
ALLOWED_ORIGINS=
